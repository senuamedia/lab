// Comprehensive comparison operator tests for f64 and i64
// Tests all 6 comparison operators with positive, negative, zero, and edge cases

// ============================================================
// F64 COMPARISON TESTS
// ============================================================

fn test_f64_greater_than() -> i64 {
    var failures: i64 = 0;

    // 5.0 > 3.0 should be true
    if 5.0 > 3.0 {
        let _pass: i64 = 0;
    } else {
        println("FAIL: 5.0 > 3.0 expected true");
        failures = failures + 1;
    }

    // 3.0 > 5.0 should be false
    if 3.0 > 5.0 {
        println("FAIL: 3.0 > 5.0 expected false");
        failures = failures + 1;
    }

    // 3.0 > 3.0 should be false
    if 3.0 > 3.0 {
        println("FAIL: 3.0 > 3.0 expected false");
        failures = failures + 1;
    }

    failures
}

