fn test_f64_negatives() -> i64 {
    var failures: i64 = 0;
    var a: f64 = -5.0;
    var b: f64 = -3.0;

    // -5.0 < -3.0 should be true
    if a < b {
        let _pass: i64 = 0;
    } else {
        println("FAIL: -5.0 < -3.0 expected true");
        failures = failures + 1;
    }

    // -3.0 > -5.0 should be true
    if b > a {
        let _pass: i64 = 0;
    } else {
        println("FAIL: -3.0 > -5.0 expected true");
        failures = failures + 1;
    }

    // -5.0 > -3.0 should be false
    if a > b {
        println("FAIL: -5.0 > -3.0 expected false");
        failures = failures + 1;
    }

    // -3.0 < -5.0 should be false
    if b < a {
        println("FAIL: -3.0 < -5.0 expected false");
        failures = failures + 1;
    }

    // -3.0 >= -3.0 should be true
    if b >= b {
        let _pass: i64 = 0;
    } else {
        println("FAIL: -3.0 >= -3.0 expected true");
        failures = failures + 1;
    }

    // -5.0 <= -5.0 should be true
    if a <= a {
        let _pass: i64 = 0;
    } else {
        println("FAIL: -5.0 <= -5.0 expected true");
        failures = failures + 1;
    }

    failures
}

fn test_f64_zero() -> i64 {
    var failures: i64 = 0;
    var zero: f64 = 0.0;
    var neg_zero: f64 = -0.0;
    var pos: f64 = 1.0;
    var neg: f64 = -1.0;

    // 0.0 == 0.0
    if zero == zero {
        let _pass: i64 = 0;
    } else {
        println("FAIL: 0.0 == 0.0 expected true");
        failures = failures + 1;
    }

    // 0.0 == -0.0 (IEEE 754: positive and negative zero are equal)
    if zero == neg_zero {
        let _pass: i64 = 0;
    } else {
        println("FAIL: 0.0 == -0.0 expected true");
        failures = failures + 1;
    }

    // 0.0 > -1.0
    if zero > neg {
        let _pass: i64 = 0;
    } else {
        println("FAIL: 0.0 > -1.0 expected true");
        failures = failures + 1;
    }

    // 0.0 < 1.0
    if zero < pos {
        let _pass: i64 = 0;
    } else {
        println("FAIL: 0.0 < 1.0 expected true");
        failures = failures + 1;
    }

    // 0.0 >= 0.0
    if zero >= zero {
        let _pass: i64 = 0;
    } else {
        println("FAIL: 0.0 >= 0.0 expected true");
        failures = failures + 1;
    }

    // 0.0 <= 0.0
    if zero <= zero {
        let _pass: i64 = 0;
    } else {
        println("FAIL: 0.0 <= 0.0 expected true");
        failures = failures + 1;
    }

    failures
}

fn test_f64_if_else_branch() -> i64 {
    var failures: i64 = 0;
    var x: f64 = 7.5;
    var y: f64 = 3.2;
    var result: i64 = 0;

    // Conditional branching on f64 comparison
    if x > y {
        result = 1;
    } else {
        result = 0;
    }
    if result != 1 {
        println("FAIL: f64 if/else branch (x > y)");
        failures = failures + 1;
    }

    // Chained if/else
    if x < 5.0 {
        result = 10;
    } else {
        if x < 8.0 {
            result = 20;
        } else {
            result = 30;
        }
    }
    // 7.5 is >= 5.0 and < 8.0, so result should be 20
    if result != 20 {
        println("FAIL: f64 chained if/else expected 20");
        failures = failures + 1;
    }

    failures
}

