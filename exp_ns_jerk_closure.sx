    println("#  Original H_v1:    A* = 0.298  (gap = 0.838)           #");
    println("#  Criterion J:      A* = 0.385  (10.4% closed)          #");
    println("#  Criterion L:      A* = 0.755  (54.6% closed)          #");
    println("#  Current best:     see above                            #");
    println("#                                                          #");
    println("#  Every new level adds to H. Every level is a dual       #");
    println("#  number. The gap narrows with each observation.         #");
