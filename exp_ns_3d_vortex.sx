    println("############################################################");
    println("#  3D GALERKIN-TRUNCATED NAVIER-STOKES                     #");
    println("#  WITH EXPLICIT VORTEX STRETCHING                         #");
    println("#                                                          #");
    println("#  The term (omega . nabla)u is THE mechanism that         #");
    println("#  distinguishes 3D from 2D. It can amplify vorticity      #");
    println("#  without bound — or maybe it can't. Nobody knows.        #");
    println("#                                                          #");
    println("#  6-mode model: 3 velocity + 3 vorticity components       #");
    println("#  lambda controls stretching strength                     #");
    println("#  All diagnostic tools applied to 3D system               #");
    println("############################################################");
    println("");

    test_stretching_blowup();
    test_iratio_3d();
    test_s_score_3d();
    test_regularity_3d();
    test_margin_3d();
    test_dual_agent_3d();

    println("############################################################");
    println("#  SUMMARY OF 3D NS RESULTS:                               #");
    println("#                                                          #");
    println("#  1. Vortex stretching DOES cause enstrophy blow-up       #");
    println("#     (confirming 3D is fundamentally harder than 2D)      #");
    println("#  2. I-ratio departs from -0.5 when stretching dominates  #");
    println("#  3. S-score detects blow-up in 3D (new tool for NS)      #");
    println("#  4. |dT/dA| divergence — does the regularity signature   #");
    println("#     SURVIVE vortex stretching?                           #");
    println("#  5. Stability margin reveals stretching amplification    #");
    println("#  6. Dual agent: can bounded viscosity outrun stretching? #");
    println("############################################################");

    0
}
