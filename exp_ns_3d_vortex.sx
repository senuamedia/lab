// 3D Galerkin-Truncated Navier-Stokes with Vortex Stretching
//
// THE KEY DIFFERENCE between 2D and 3D NS:
//   2D: vorticity is scalar, no stretching → global regularity PROVEN
//   3D: vorticity is a vector, stretching term ω·∇u can amplify
//       vorticity without bound → regularity UNKNOWN (millennium problem)
//
// Model: 6-mode truncation of 3D vorticity equation
//   dω/dt + (u·∇)ω = (ω·∇)u + ν∇²ω
//
//   First 3 modes: velocity components (u, v, w) at wavenumber k1=1
//   Last 3 modes: vorticity components (ωx, ωy, ωz) at wavenumber k2=2
//
// The vortex stretching term (ω·∇)u couples vorticity to velocity
// gradients. In 3D, this term has NO sign — it can amplify or diminish
// vorticity depending on alignment. THIS is what makes 3D hard.
//
// Evolution:
//   du_i/dt = -ν·k1²·u_i + Σ_j (ω_j · ∂u_i/∂x_j)  [stretching]
//                          - Σ_j (u_j · ∂ω_i/∂x_j)  [advection]
//
// In Fourier truncation with coupling constants:
//   du/dt = -ν·k1²·u + σ·(ωy·w - ωz·v)     [stretching drives velocity]
//   dv/dt = -ν·k1²·v + σ·(ωz·u - ωx·w)
//   dw/dt = -ν·k1²·w + σ·(ωx·v - ωy·u)
//   dωx/dt = -ν·k2²·ωx + λ·(ωy·∂w/∂y + ωz·∂u/∂z)  [vortex stretching]
//   dωy/dt = -ν·k2²·ωy + λ·(ωz·∂u/∂x + ωx·∂w/∂z)
//   dωz/dt = -ν·k2²·ωz + λ·(ωx·∂v/∂y + ωy·∂u/∂x)
//
// In the truncated model, velocity gradients ≈ k·u, so:
//   dωx/dt = -ν·k2²·ωx + λ·k1·(ωy·w + ωz·u)
//   dωy/dt = -ν·k2²·ωy + λ·k1·(ωz·u + ωx·w)
//   dωz/dt = -ν·k2²·ωz + λ·k1·(ωx·v + ωy·u)
//
// σ controls feedback from vorticity to velocity
// λ controls vortex stretching strength
// When λ=0 → 2D-like (no stretching) → stable
// When λ>0 → 3D stretching → possible blow-up
//
// We test ALL our diagnostic tools on this system:
//   1. I-ratio between diffusion and stretching
//   2. S-score for convergence detection
//   3. |∂T/∂A| → ∞ regularity signature
//   4. Stability margin M(t) from perturbation probing
//   5. Dual agent (order vs chaos)

fn abs_f64(x: f64) -> f64 {
    if x >= 0.0 { x } else { 0.0 - x }
}

fn max_f64(a: f64, b: f64) -> f64 { if a > b { a } else { b } }

fn clamp(x: f64, lo: f64, hi: f64) -> f64 {
    if x < lo { return lo; }
    if x > hi { return hi; }
    x
}

// Wavenumbers
// k1 = 1 (velocity modes), k2 = 2 (vorticity modes)

// Diffusion forces (stabilising)
fn diff_u(u: f64, nu: f64) -> f64 { 0.0 - nu * 1.0 * u; }
fn diff_v(v: f64, nu: f64) -> f64 { 0.0 - nu * 1.0 * v; }
fn diff_w(w: f64, nu: f64) -> f64 { 0.0 - nu * 1.0 * w; }
fn diff_ox(ox: f64, nu: f64) -> f64 { 0.0 - nu * 4.0 * ox; }
fn diff_oy(oy: f64, nu: f64) -> f64 { 0.0 - nu * 4.0 * oy; }
fn diff_oz(oz: f64, nu: f64) -> f64 { 0.0 - nu * 4.0 * oz; }

// Stretching forces (the 3D-specific term, potentially destabilising)
// Velocity driven by vorticity cross-product (σ coupling)
fn stretch_u(v: f64, w: f64, oy: f64, oz: f64, sigma: f64) -> f64 {
    sigma * (oy * w - oz * v)
}
fn stretch_v(u: f64, w: f64, ox: f64, oz: f64, sigma: f64) -> f64 {
    sigma * (oz * u - ox * w)
}
fn stretch_w(u: f64, v: f64, ox: f64, oy: f64, sigma: f64) -> f64 {
    sigma * (ox * v - oy * u)
}

// Vortex stretching: ω·∇u term (λ coupling, k1 wavenumber)
// THIS is the term that makes 3D NS hard
fn vstretch_ox(u: f64, w: f64, oy: f64, oz: f64, lambda: f64) -> f64 {
    lambda * 1.0 * (oy * w + oz * u)
}
fn vstretch_oy(u: f64, w: f64, ox: f64, oz: f64, lambda: f64) -> f64 {
    lambda * 1.0 * (oz * u + ox * w)
}
fn vstretch_oz(u: f64, v: f64, ox: f64, oy: f64, lambda: f64) -> f64 {
    lambda * 1.0 * (ox * v + oy * u)
}

// Total energy: ½(u² + v² + w²) + ½(ωx² + ωy² + ωz²)
fn total_energy(u: f64, v: f64, w: f64, ox: f64, oy: f64, oz: f64) -> f64 {
    0.5 * (u * u + v * v + w * w + ox * ox + oy * oy + oz * oz)
}

// Enstrophy: ½(ωx² + ωy² + ωz²) — key quantity for regularity
fn enstrophy(ox: f64, oy: f64, oz: f64) -> f64 {
    0.5 * (ox * ox + oy * oy + oz * oz)
}

// I-ratio between diffusion and stretching 6-vectors
fn iratio_6(d0: f64, d1: f64, d2: f64, d3: f64, d4: f64, d5: f64,
            s0: f64, s1: f64, s2: f64, s3: f64, s4: f64, s5: f64) -> f64 {
    let cross: f64 = d0 * s0 + d1 * s1 + d2 * s2 + d3 * s3 + d4 * s4 + d5 * s5;
    var ind: f64 = d0 * d0 + d1 * d1 + d2 * d2 + d3 * d3 + d4 * d4 + d5 * d5;
    ind = ind + s0 * s0 + s1 * s1 + s2 * s2 + s3 * s3 + s4 * s4 + s5 * s5;
    if ind < 0.0000000001 { return 0.0; }
    cross / ind
}

// One timestep of the 6-mode 3D NS model
// Returns component 'which' (0=u, 1=v, 2=w, 3=ox, 4=oy, 5=oz)
fn step6(u: f64, v: f64, w: f64, ox: f64, oy: f64, oz: f64,
         nu: f64, sigma: f64, lambda: f64, dt: f64, which: i64) -> f64 {
    // Velocity evolution: diffusion + stretching feedback
    let du: f64 = diff_u(u, nu) + stretch_u(v, w, oy, oz, sigma);
    let dv: f64 = diff_v(v, nu) + stretch_v(u, w, ox, oz, sigma);
    let dw: f64 = diff_w(w, nu) + stretch_w(u, v, ox, oy, sigma);
    // Vorticity evolution: diffusion + vortex stretching (THE 3D term)
    let dox: f64 = diff_ox(ox, nu) + vstretch_ox(u, w, oy, oz, lambda);
    let doy: f64 = diff_oy(oy, nu) + vstretch_oy(u, w, ox, oz, lambda);
    let doz: f64 = diff_oz(oz, nu) + vstretch_oz(u, v, ox, oy, lambda);

    if which == 0 { return u + dt * du; }
    if which == 1 { return v + dt * dv; }
    if which == 2 { return w + dt * dw; }
    if which == 3 { return ox + dt * dox; }
    if which == 4 { return oy + dt * doy; }
    return oz + dt * doz
}

// Evolve for N steps, return component 'which'
fn evolve6(amp: f64, nu: f64, sigma: f64, lambda: f64,
           dt: f64, steps: i64, which: i64) -> f64 {
    let pi: f64 = 3.14159265358979;
    // Initial condition: sinusoidal velocity, small vorticity
    var u: f64 = amp * sin(pi * 0.3);
    var v: f64 = amp * sin(pi * 0.7);
    var w: f64 = amp * sin(pi * 1.1);
    var ox: f64 = amp * 0.1 * sin(pi * 0.5);
    var oy: f64 = amp * 0.1 * sin(pi * 0.9);
    var oz: f64 = amp * 0.1 * sin(pi * 1.3);
    var s: i64 = 0;

    while s < steps {
        let nu2: f64 = step6(u, v, w, ox, oy, oz, nu, sigma, lambda, dt, 0);
        let nv2: f64 = step6(u, v, w, ox, oy, oz, nu, sigma, lambda, dt, 1);
        let nw2: f64 = step6(u, v, w, ox, oy, oz, nu, sigma, lambda, dt, 2);
        let nox: f64 = step6(u, v, w, ox, oy, oz, nu, sigma, lambda, dt, 3);
        let noy: f64 = step6(u, v, w, ox, oy, oz, nu, sigma, lambda, dt, 4);
        let noz: f64 = step6(u, v, w, ox, oy, oz, nu, sigma, lambda, dt, 5);
        u = nu2; v = nv2; w = nw2; ox = nox; oy = noy; oz = noz;
        s = s + 1;
    }
    if which == 0 { return u; }
    if which == 1 { return v; }
    if which == 2 { return w; }
    if which == 3 { return ox; }
    if which == 4 { return oy; }
    oz
}

// Blow-up time: steps until enstrophy exceeds threshold
fn blowup6(amp: f64, nu: f64, sigma: f64, lambda: f64,
           dt: f64, max_steps: i64, thresh: f64) -> i64 {
    let pi: f64 = 3.14159265358979;
    var u: f64 = amp * sin(pi * 0.3);
    var v: f64 = amp * sin(pi * 0.7);
    var w: f64 = amp * sin(pi * 1.1);
    var ox: f64 = amp * 0.1 * sin(pi * 0.5);
    var oy: f64 = amp * 0.1 * sin(pi * 0.9);
    var oz: f64 = amp * 0.1 * sin(pi * 1.3);
    var s: i64 = 0;

    while s < max_steps {
        let e: f64 = enstrophy(ox, oy, oz);
        if e > thresh { return s; }
        let nu2: f64 = step6(u, v, w, ox, oy, oz, nu, sigma, lambda, dt, 0);
        let nv2: f64 = step6(u, v, w, ox, oy, oz, nu, sigma, lambda, dt, 1);
        let nw2: f64 = step6(u, v, w, ox, oy, oz, nu, sigma, lambda, dt, 2);
        let nox: f64 = step6(u, v, w, ox, oy, oz, nu, sigma, lambda, dt, 3);
        let noy: f64 = step6(u, v, w, ox, oy, oz, nu, sigma, lambda, dt, 4);
        let noz: f64 = step6(u, v, w, ox, oy, oz, nu, sigma, lambda, dt, 5);
        u = nu2; v = nv2; w = nw2; ox = nox; oy = noy; oz = noz;
        s = s + 1;
    }
    max_steps
}

// ============================================================================
// Exp 1: 2D vs 3D — Does Vortex Stretching Cause Blow-Up?
//
// Run with λ=0 (no stretching, 2D-like) and increasing λ.
// If stretching causes blow-up, enstrophy diverges at finite time.
// ============================================================================

fn test_stretching_blowup() -> i64 {
    println("=== Exp 1: Vortex Stretching and Blow-Up ===");
    println("  lambda=0: no stretching (2D-like, should be stable)");
    println("  lambda>0: 3D stretching (may cause blow-up)");
    println("  Measuring enstrophy divergence");
    println("");

    let amp: f64 = 1.0;
    let sigma: f64 = 0.5;
    let dt: f64 = 0.0001;
    let max_s: i64 = 50000;
    let thresh: f64 = 1000.0;

    println("  nu      lambda   T_blowup   Enstrophy(t=5000)  Regime");

    // Sweep nu and lambda
    var ni: i64 = 0;
    while ni < 3 {
        var nu: f64 = 0.1;
        if ni == 1 { nu = 0.01; }
        if ni == 2 { nu = 0.001; }

        var li: i64 = 0;
        while li < 5 {
            var lambda: f64 = 0.0;
            if li == 1 { lambda = 0.1; }
            if li == 2 { lambda = 0.5; }
            if li == 3 { lambda = 1.0; }
            if li == 4 { lambda = 2.0; }

            let tb: i64 = blowup6(amp, nu, sigma, lambda, dt, max_s, thresh);

            // Get enstrophy at t=5000
            let ox5: f64 = evolve6(amp, nu, sigma, lambda, dt, 5000, 3);
            let oy5: f64 = evolve6(amp, nu, sigma, lambda, dt, 5000, 4);
            let oz5: f64 = evolve6(amp, nu, sigma, lambda, dt, 5000, 5);
            let enst: f64 = enstrophy(ox5, oy5, oz5);

            print("  ");
            print_f64(nu);
            print("  ");
            print_f64(lambda);
            print("  ");
            print_i64(tb);
            print("        ");
            print_f64(enst);
            if tb < max_s {
                println("  BLOW-UP");
            } else {
                if enst > 1.0 { println("  GROWING"); }
                else { println("  STABLE"); }
            }

            li = li + 1;
        }
        ni = ni + 1;
    }
    println("");
    0
}

// ============================================================================
// Exp 2: I-Ratio — Diffusion vs Stretching Force Balance
//
// In 3D NS, the competition between diffusion (ν∇²ω) and stretching
// (ω·∇u) determines regularity. If they balance → smooth. If stretching
// wins → blow-up.
//
// I-ratio between the 6-vector diffusion force and 6-vector stretching
// force should show:
//   I ≈ -0.5: balanced (smooth, like 2D)
//   I departing: stretching dominating (blow-up risk)
// ============================================================================

fn test_iratio_3d() -> i64 {
    println("=== Exp 2: I-Ratio Between Diffusion and Stretching ===");
    println("  I ≈ -0.5: forces balanced (smooth flow)");
    println("  I departing: stretching dominates (blow-up risk)");
    println("");

    let amp: f64 = 1.0;
    let sigma: f64 = 0.5;
    let dt: f64 = 0.0001;
    let nu: f64 = 0.01;

    println("  lambda   Time    I-ratio      Enstrophy    Interpretation");

    var li: i64 = 0;
    while li < 4 {
        var lambda: f64 = 0.0;
        if li == 1 { lambda = 0.3; }
        if li == 2 { lambda = 0.7; }
        if li == 3 { lambda = 1.5; }

        var ti: i64 = 0;
        while ti < 5 {
            var t_steps: i64 = 1000;
            if ti == 1 { t_steps = 3000; }
            if ti == 2 { t_steps = 5000; }
            if ti == 3 { t_steps = 8000; }
            if ti == 4 { t_steps = 12000; }

            let u: f64 = evolve6(amp, nu, sigma, lambda, dt, t_steps, 0);
            let v: f64 = evolve6(amp, nu, sigma, lambda, dt, t_steps, 1);
            let w: f64 = evolve6(amp, nu, sigma, lambda, dt, t_steps, 2);
            let ox: f64 = evolve6(amp, nu, sigma, lambda, dt, t_steps, 3);
            let oy: f64 = evolve6(amp, nu, sigma, lambda, dt, t_steps, 4);
            let oz: f64 = evolve6(amp, nu, sigma, lambda, dt, t_steps, 5);

            // Diffusion forces
            let fd0: f64 = diff_u(u, nu);
            let fd1: f64 = diff_v(v, nu);
            let fd2: f64 = diff_w(w, nu);
            let fd3: f64 = diff_ox(ox, nu);
            let fd4: f64 = diff_oy(oy, nu);
            let fd5: f64 = diff_oz(oz, nu);

            // Stretching forces (velocity + vortex stretching combined)
            let fs0: f64 = stretch_u(v, w, oy, oz, sigma);
            let fs1: f64 = stretch_v(u, w, ox, oz, sigma);
            let fs2: f64 = stretch_w(u, v, ox, oy, sigma);
            let fs3: f64 = vstretch_ox(u, w, oy, oz, lambda);
            let fs4: f64 = vstretch_oy(u, w, ox, oz, lambda);
            let fs5: f64 = vstretch_oz(u, v, ox, oy, lambda);

            let ir: f64 = iratio_6(fd0, fd1, fd2, fd3, fd4, fd5,
                                    fs0, fs1, fs2, fs3, fs4, fs5);

            let enst: f64 = enstrophy(ox, oy, oz);

            print("  ");
            print_f64(lambda);
            print("  ");
            print_i64(t_steps);
            print("    ");
            print_f64(ir);
            print("  ");
            print_f64(enst);

            let dept: f64 = abs_f64(ir + 0.5);
            if dept < 0.1 { println("  BALANCED"); }
            else {
                if dept < 0.3 { println("  DEPARTING"); }
                else { println("  UNBALANCED"); }
            }

            ti = ti + 1;
        }
        println("");
        li = li + 1;
    }
    0
}

// ============================================================================
// Exp 3: S-Score for 3D NS — Does S Detect Blow-Up?
//
// Compute S from the enstrophy time series.
// S > 0: enstrophy converging (smooth)
// S < 0: enstrophy diverging (blow-up approaching)
// ============================================================================

fn s_score_3d(amp: f64, nu: f64, sigma: f64, lambda: f64,
              dt: f64, t_start: i64, probe_steps: i64) -> f64 {
    let pi: f64 = 3.14159265358979;
    // Evolve to t_start
    var u: f64 = amp * sin(pi * 0.3);
    var v: f64 = amp * sin(pi * 0.7);
    var w: f64 = amp * sin(pi * 1.1);
    var ox: f64 = amp * 0.1 * sin(pi * 0.5);
    var oy: f64 = amp * 0.1 * sin(pi * 0.9);
    var oz: f64 = amp * 0.1 * sin(pi * 1.3);
    var s: i64 = 0;

    while s < t_start {
        let nu2: f64 = step6(u, v, w, ox, oy, oz, nu, sigma, lambda, dt, 0);
        let nv2: f64 = step6(u, v, w, ox, oy, oz, nu, sigma, lambda, dt, 1);
        let nw2: f64 = step6(u, v, w, ox, oy, oz, nu, sigma, lambda, dt, 2);
        let nox: f64 = step6(u, v, w, ox, oy, oz, nu, sigma, lambda, dt, 3);
        let noy: f64 = step6(u, v, w, ox, oy, oz, nu, sigma, lambda, dt, 4);
        let noz: f64 = step6(u, v, w, ox, oy, oz, nu, sigma, lambda, dt, 5);
        u = nu2; v = nv2; w = nw2; ox = nox; oy = noy; oz = noz;
        s = s + 1;
    }

    // Now compute S over probe window
    var prev_enst: f64 = enstrophy(ox, oy, oz);
    var early_drift: f64 = 0.0;
    var late_drift: f64 = 0.0;
    var count_e: i64 = 0;
    var count_l: i64 = 0;
    let half: i64 = probe_steps / 2;
    var step: i64 = 0;

    while step < probe_steps {
        let nu2: f64 = step6(u, v, w, ox, oy, oz, nu, sigma, lambda, dt, 0);
        let nv2: f64 = step6(u, v, w, ox, oy, oz, nu, sigma, lambda, dt, 1);
        let nw2: f64 = step6(u, v, w, ox, oy, oz, nu, sigma, lambda, dt, 2);
        let nox: f64 = step6(u, v, w, ox, oy, oz, nu, sigma, lambda, dt, 3);
        let noy: f64 = step6(u, v, w, ox, oy, oz, nu, sigma, lambda, dt, 4);
        let noz: f64 = step6(u, v, w, ox, oy, oz, nu, sigma, lambda, dt, 5);
        u = nu2; v = nv2; w = nw2; ox = nox; oy = noy; oz = noz;

        let enst: f64 = enstrophy(ox, oy, oz);
        let d: f64 = abs_f64(enst - prev_enst);

        if step < half { early_drift = early_drift + d; count_e = count_e + 1; }
        else { late_drift = late_drift + d; count_l = count_l + 1; }

        prev_enst = enst;
        step = step + 1;
    }

    if count_e > 0 { early_drift = early_drift / (count_e as f64); }
    if count_l > 0 { late_drift = late_drift / (count_l as f64); }
    if early_drift > 0.0000000001 {
        1.0 - late_drift / early_drift
    } else {
        if late_drift < 0.0000000001 { 1.0 } else { 0.0 - 1.0 }
    }
}

fn test_s_score_3d() -> i64 {
    println("=== Exp 3: S-Score for 3D NS ===");
    println("  S > 0: enstrophy converging (smooth flow)");
    println("  S < 0: enstrophy diverging (blow-up approaching)");
    println("");

    let amp: f64 = 1.0;
    let sigma: f64 = 0.5;
    let dt: f64 = 0.0001;
    let probe: i64 = 2000;

    println("  nu     lambda   Time    S-score    Prediction");

    var ni: i64 = 0;
    while ni < 2 {
        var nu: f64 = 0.01;
        if ni == 1 { nu = 0.001; }

        var li: i64 = 0;
        while li < 3 {
            var lambda: f64 = 0.0;
            if li == 1 { lambda = 0.5; }
            if li == 2 { lambda = 1.5; }

            var ti: i64 = 0;
            while ti < 4 {
                var t_start: i64 = 0;
                if ti == 1 { t_start = 3000; }
                if ti == 2 { t_start = 6000; }
                if ti == 3 { t_start = 10000; }

                let sc: f64 = s_score_3d(amp, nu, sigma, lambda, dt, t_start, probe);

                print("  ");
                print_f64(nu);
                print("  ");
                print_f64(lambda);
                print("  ");
                print_i64(t_start);
                print("    ");
                print_f64(sc);

                if sc > 0.2 { println("  CONVERGING (smooth)"); }
                else {
                    if sc > 0.0 - 0.2 { println("  MARGINAL"); }
                    else { println("  DIVERGING (blow-up risk)"); }
                }

                ti = ti + 1;
            }
            println("");
            li = li + 1;
        }
        ni = ni + 1;
    }
    0
}

// ============================================================================
// Exp 4: THE REGULARITY QUESTION — |∂T/∂A| → ∞ as A → 0?
//
// Does blow-up time diverge as initial amplitude shrinks?
// If YES → smooth data prevents blow-up → evidence for regularity
// If NO → finite-time singularity exists → evidence against regularity
//
// Test with vortex stretching (λ > 0), the 3D-specific mechanism.
// This is the KEY experiment: does the signature survive 3D stretching?
// ============================================================================

fn test_regularity_3d() -> i64 {
    println("=== Exp 4: THE REGULARITY QUESTION IN 3D ===");
    println("  |dT/dA| as A → 0 for different stretching strengths");
    println("  If |dT/dA| → infinity: smooth data prevents blow-up");
    println("  If |dT/dA| → constant: finite-time singularity exists");
    println("");

    let sigma: f64 = 0.5;
    let dt: f64 = 0.0001;
    let max_s: i64 = 100000;
    let thresh: f64 = 100.0;

    // Test multiple stretching strengths
    var li: i64 = 0;
    while li < 4 {
        var lambda: f64 = 0.0;
        var nu: f64 = 0.01;
        if li == 1 { lambda = 0.3; }
        if li == 2 { lambda = 0.7; nu = 0.01; }
        if li == 3 { lambda = 1.5; nu = 0.01; }

        print("  --- lambda=");
        print_f64(lambda);
        print(", nu=");
        print_f64(nu);
        println(" ---");
        println("  Amplitude   T_blowup     |dT/dA|      R=|dT/dA|*A");

        var prev_t: f64 = 0.0;
        var prev_a: f64 = 0.0;
        var ai: i64 = 0;
        while ai < 7 {
            var amp: f64 = 2.0;
            if ai == 1 { amp = 1.0; }
            if ai == 2 { amp = 0.5; }
            if ai == 3 { amp = 0.25; }
            if ai == 4 { amp = 0.125; }
            if ai == 5 { amp = 0.0625; }
            if ai == 6 { amp = 0.03125; }

            let tb: i64 = blowup6(amp, nu, sigma, lambda, dt, max_s, thresh);
            let tb_f: f64 = tb as f64;

            print("  ");
            print_f64(amp);
            print("     ");
            print_i64(tb);

            if ai > 0 {
                let da: f64 = amp - prev_a;
                if abs_f64(da) > 0.00001 {
                    let dt_da: f64 = abs_f64((tb_f - prev_t) / da);
                    let ratio: f64 = dt_da * amp;
                    print("        ");
                    print_f64(dt_da);
                    print("  R=");
                    print_f64(ratio);
                }
            }
            println("");

            prev_t = tb_f;
            prev_a = amp;
            ai = ai + 1;
        }

        println("");
        li = li + 1;
    }

    println("  INTERPRETATION:");
    println("  If |dT/dA| grows as A shrinks → regularity signature present");
    println("  If |dT/dA| stays constant → finite-time singularity");
    println("  R = |dT/dA|*A diverging → divergence FASTER than 1/A");
    println("");
    0
}

// ============================================================================
// Exp 5: Stability Margin M(t) with Vortex Stretching
//
// Perturb the vorticity field, measure divergence.
// In 3D, stretching can AMPLIFY perturbations in vorticity —
// this is the mechanism that might cause blow-up.
// ============================================================================

fn margin_3d(amp: f64, nu: f64, sigma: f64, lambda: f64,
             dt: f64, t_start: i64, eps: f64, probe: i64) -> f64 {
    let pi: f64 = 3.14159265358979;
    // Evolve to t_start
    var u: f64 = amp * sin(pi * 0.3);
    var v: f64 = amp * sin(pi * 0.7);
    var w: f64 = amp * sin(pi * 1.1);
    var ox: f64 = amp * 0.1 * sin(pi * 0.5);
    var oy: f64 = amp * 0.1 * sin(pi * 0.9);
    var oz: f64 = amp * 0.1 * sin(pi * 1.3);
    var s: i64 = 0;

    while s < t_start {
        let nu2: f64 = step6(u, v, w, ox, oy, oz, nu, sigma, lambda, dt, 0);
        let nv2: f64 = step6(u, v, w, ox, oy, oz, nu, sigma, lambda, dt, 1);
        let nw2: f64 = step6(u, v, w, ox, oy, oz, nu, sigma, lambda, dt, 2);
        let nox: f64 = step6(u, v, w, ox, oy, oz, nu, sigma, lambda, dt, 3);
        let noy: f64 = step6(u, v, w, ox, oy, oz, nu, sigma, lambda, dt, 4);
        let noz: f64 = step6(u, v, w, ox, oy, oz, nu, sigma, lambda, dt, 5);
        u = nu2; v = nv2; w = nw2; ox = nox; oy = noy; oz = noz;
        s = s + 1;
    }

    // Now run unperturbed and perturbed (kick ωz by eps)
    var au: f64 = u; var av: f64 = v; var aw: f64 = w;
    var aox: f64 = ox; var aoy: f64 = oy; var aoz: f64 = oz;
    var bu: f64 = u; var bv: f64 = v; var bw: f64 = w;
    var box_v: f64 = ox; var boy: f64 = oy; var boz: f64 = oz + eps;
    var p: i64 = 0;

    while p < probe {
        let na0: f64 = step6(au, av, aw, aox, aoy, aoz, nu, sigma, lambda, dt, 0);
        let na1: f64 = step6(au, av, aw, aox, aoy, aoz, nu, sigma, lambda, dt, 1);
        let na2: f64 = step6(au, av, aw, aox, aoy, aoz, nu, sigma, lambda, dt, 2);
        let na3: f64 = step6(au, av, aw, aox, aoy, aoz, nu, sigma, lambda, dt, 3);
        let na4: f64 = step6(au, av, aw, aox, aoy, aoz, nu, sigma, lambda, dt, 4);
        let na5: f64 = step6(au, av, aw, aox, aoy, aoz, nu, sigma, lambda, dt, 5);

        let nb0: f64 = step6(bu, bv, bw, box_v, boy, boz, nu, sigma, lambda, dt, 0);
        let nb1: f64 = step6(bu, bv, bw, box_v, boy, boz, nu, sigma, lambda, dt, 1);
        let nb2: f64 = step6(bu, bv, bw, box_v, boy, boz, nu, sigma, lambda, dt, 2);
        let nb3: f64 = step6(bu, bv, bw, box_v, boy, boz, nu, sigma, lambda, dt, 3);
        let nb4: f64 = step6(bu, bv, bw, box_v, boy, boz, nu, sigma, lambda, dt, 4);
        let nb5: f64 = step6(bu, bv, bw, box_v, boy, boz, nu, sigma, lambda, dt, 5);

        au = na0; av = na1; aw = na2; aox = na3; aoy = na4; aoz = na5;
        bu = nb0; bv = nb1; bw = nb2; box_v = nb3; boy = nb4; boz = nb5;
        p = p + 1;
    }

    // Compute divergence
    let d0: f64 = (au - bu) * (au - bu);
    let d1: f64 = (av - bv) * (av - bv);
    let d2: f64 = (aw - bw) * (aw - bw);
    let d3: f64 = (aox - box_v) * (aox - box_v);
    let d4: f64 = (aoy - boy) * (aoy - boy);
    let d5: f64 = (aoz - boz) * (aoz - boz);
    sqrt(d0 + d1 + d2 + d3 + d4 + d5) / abs_f64(eps)
}

fn test_margin_3d() -> i64 {
    println("=== Exp 5: Stability Margin with Vortex Stretching ===");
    println("  Perturbation on vorticity (ωz += eps)");
    println("  3D stretching amplifies vorticity perturbations");
    println("");

    let amp: f64 = 1.0;
    let sigma: f64 = 0.5;
    let dt: f64 = 0.0001;
    let eps: f64 = 0.01;
    let probe: i64 = 500;
    let nu: f64 = 0.01;

    println("  lambda   Time    M(t)         dM/dt       Prediction");

    var li: i64 = 0;
    while li < 3 {
        var lambda: f64 = 0.0;
        if li == 1 { lambda = 0.5; }
        if li == 2 { lambda = 1.5; }

        var prev_m: f64 = 0.0;
        var ti: i64 = 0;
        while ti < 5 {
            var t_start: i64 = 0;
            if ti == 1 { t_start = 2000; }
            if ti == 2 { t_start = 5000; }
            if ti == 3 { t_start = 8000; }
            if ti == 4 { t_start = 12000; }

            let m: f64 = margin_3d(amp, nu, sigma, lambda, dt, t_start, eps, probe);
            let dm: f64 = m - prev_m;

            print("  ");
            print_f64(lambda);
            print("  ");
            print_i64(t_start);
            print("    ");
            print_f64(m);
            print("  ");
            print_f64(dm);

            if dm > 0.01 { println("  FRAGILITY INCREASING"); }
            else {
                if dm < 0.0 - 0.01 { println("  STABILISING"); }
                else { println("  STABLE"); }
            }

            prev_m = m;
            ti = ti + 1;
        }
        println("");
        li = li + 1;
    }
    0
}

// ============================================================================
// Exp 6: Dual Agent in 3D — Can Order Outrun Stretching?
//
// The fundamental question: can adaptive viscosity (order agent) keep
// enstrophy bounded even with vortex stretching active?
//
// If YES: constructive regularity — there exists a viscosity schedule
//         that maintains smoothness
// If NO: stretching overwhelms any finite viscosity → singularity
// ============================================================================

fn blowup6_dual(amp: f64, nu: f64, sigma: f64, lambda: f64,
                dt: f64, max_steps: i64, thresh: f64, nu_art: f64) -> i64 {
    let pi: f64 = 3.14159265358979;
    var u: f64 = amp * sin(pi * 0.3);
    var v: f64 = amp * sin(pi * 0.7);
    var w: f64 = amp * sin(pi * 1.1);
    var ox: f64 = amp * 0.1 * sin(pi * 0.5);
    var oy: f64 = amp * 0.1 * sin(pi * 0.9);
    var oz: f64 = amp * 0.1 * sin(pi * 1.3);
    var s: i64 = 0;

    while s < max_steps {
        let e: f64 = enstrophy(ox, oy, oz);
        if e > thresh { return s; }
        // Order agent: adds viscosity to BOTH velocity and vorticity
        let nu_eff: f64 = nu + nu_art;
        let nu2: f64 = step6(u, v, w, ox, oy, oz, nu_eff, sigma, lambda, dt, 0);
        let nv2: f64 = step6(u, v, w, ox, oy, oz, nu_eff, sigma, lambda, dt, 1);
        let nw2: f64 = step6(u, v, w, ox, oy, oz, nu_eff, sigma, lambda, dt, 2);
        let nox: f64 = step6(u, v, w, ox, oy, oz, nu_eff, sigma, lambda, dt, 3);
        let noy: f64 = step6(u, v, w, ox, oy, oz, nu_eff, sigma, lambda, dt, 4);
        let noz: f64 = step6(u, v, w, ox, oy, oz, nu_eff, sigma, lambda, dt, 5);
        u = nu2; v = nv2; w = nw2; ox = nox; oy = noy; oz = noz;
        s = s + 1;
    }
    max_steps
}

fn test_dual_agent_3d() -> i64 {
    println("=== Exp 6: Can Order Outrun Vortex Stretching? ===");
    println("  Dual agent with increasing order strength");
    println("  If bounded nu_art prevents blow-up → constructive regularity");
    println("");

    let amp: f64 = 1.0;
    let sigma: f64 = 0.5;
    let dt: f64 = 0.0001;
    let max_s: i64 = 50000;
    let thresh: f64 = 100.0;
    let nu: f64 = 0.01;

    println("  lambda   nu_art    T_blowup   vs baseline  Interpretation");

    var li: i64 = 0;
    while li < 3 {
        var lambda: f64 = 0.5;
        if li == 1 { lambda = 1.0; }
        if li == 2 { lambda = 2.0; }

        let t_base: i64 = blowup6(amp, nu, sigma, lambda, dt, max_s, thresh);

        var oi: i64 = 0;
        while oi < 5 {
            var nu_art: f64 = 0.0;
            if oi == 1 { nu_art = 0.005; }
            if oi == 2 { nu_art = 0.01; }
            if oi == 3 { nu_art = 0.02; }
            if oi == 4 { nu_art = 0.05; }

            let tb: i64 = blowup6_dual(amp, nu, sigma, lambda, dt, max_s, thresh, nu_art);

            print("  ");
            print_f64(lambda);
            print("  ");
            print_f64(nu_art);
            print("  ");
            print_i64(tb);
            print("       ");

            if tb >= max_s {
                println("SMOOTHNESS MAINTAINED — no blow-up");
            } else {
                let gain: i64 = tb - t_base;
                if gain > 0 {
                    print("+");
                    print_i64(gain);
                    println(" steps extended");
                } else {
                    println("no improvement");
                }
            }

            oi = oi + 1;
        }
        println("");
        li = li + 1;
    }

    println("  KEY QUESTION:");
    println("  Does there exist BOUNDED nu_art that prevents blow-up");
    println("  for arbitrarily strong stretching (lambda)?");
    println("  If yes → constructive regularity evidence.");
    println("  If nu_art must grow with lambda → regularity depends on");
    println("  the growth rate: sub-linear = good, super-linear = bad.");
    println("");
    0
}

