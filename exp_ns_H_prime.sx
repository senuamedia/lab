// H': THE SELF-ADAPTING HOLISTIC SCORE
//
// H measures the system via 20 levels.
// H' measures how H's weights should change.
//
// Each level Li has a weight wi. The weights are dual numbers:
//   wi(t) = wi(t-1) + eta * d(accuracy)/d(wi)
//
// The meta-gradient d(accuracy)/d(wi) is computed by:
//   1. At each checkpoint, predict blow-up/safe using current H
//   2. Run forward a probe window to see if prediction was correct
//   3. If level Li contributed to a CORRECT prediction → increase wi
//   4. If level Li contributed to a WRONG prediction → decrease wi
//
// This is online learning: the weights adapt as the trajectory unfolds.
// More levels = more independent signals = faster convergence of weights.
//
// H'(t) = dH/d(weights) = the rate at which H is learning
// H''(t) = d²H/d(weights)² = is the learning accelerating?
//
// When H' → 0, the weights have converged. H has learned which
// levels to trust for THIS trajectory. The resolution is reached.
//
// KEY INSIGHT: the number of levels determines convergence speed.
// With 5 levels: H' converges slowly (few sensors, ambiguous)
// With 20 levels: H' converges fast (many sensors, triangulated)
// This is why adding conventional approaches HELPS even if
// individually they're weak — they constrain H' faster.

fn abs_f64(x: f64) -> f64 {
    if x >= 0.0 { x } else { 0.0 - x }
}

fn enstrophy3(ox: f64, oy: f64, oz: f64) -> f64 {
    0.5 * (ox * ox + oy * oy + oz * oz)
}

fn kinetic3(u: f64, v: f64, w: f64) -> f64 {
    0.5 * (u * u + v * v + w * w)
}

fn step6(u: f64, v: f64, w: f64, ox: f64, oy: f64, oz: f64,
         nu: f64, sigma: f64, lambda: f64, lambda2: f64,
         dt: f64, which: i64) -> f64 {
    let omega_sq: f64 = ox * ox + oy * oy + oz * oz;
    let fd_u: f64 = 0.0 - nu * 1.0 * u;
    let fd_v: f64 = 0.0 - nu * 1.0 * v;
    let fd_w: f64 = 0.0 - nu * 1.0 * w;
    let fd_ox: f64 = 0.0 - nu * 4.0 * ox;
    let fd_oy: f64 = 0.0 - nu * 4.0 * oy;
    let fd_oz: f64 = 0.0 - nu * 4.0 * oz;
    let fs_u: f64 = sigma * (oy * w - oz * v);
    let fs_v: f64 = sigma * (oz * u - ox * w);
    let fs_w: f64 = sigma * (ox * v - oy * u);
    let fv_ox: f64 = lambda * (oy * w + oz * u);
    let fv_oy: f64 = lambda * (oz * u + ox * w);
    let fv_oz: f64 = lambda * (ox * v + oy * u);
    let fq_ox: f64 = lambda2 * omega_sq * ox;
    let fq_oy: f64 = lambda2 * omega_sq * oy;
    let fq_oz: f64 = lambda2 * omega_sq * oz;
    if which == 0 { return u + dt * (fd_u + fs_u); }
    if which == 1 { return v + dt * (fd_v + fs_v); }
    if which == 2 { return w + dt * (fd_w + fs_w); }
    if which == 3 { return ox + dt * (fd_ox + fv_ox + fq_ox); }
    if which == 4 { return oy + dt * (fd_oy + fv_oy + fq_oy); }
    oz + dt * (fd_oz + fv_oz + fq_oz)
}

fn actually_blows_up(amp: f64, nu: f64, sigma: f64, lambda: f64, lambda2: f64,
                     dt: f64, max_steps: i64) -> i64 {
    let pi: f64 = 3.14159265358979;
    var u: f64 = amp * sin(pi * 0.3);
    var v: f64 = amp * sin(pi * 0.7);
    var w: f64 = amp * sin(pi * 1.1);
    var ox: f64 = amp * 0.1 * sin(pi * 0.5);
    var oy: f64 = amp * 0.1 * sin(pi * 0.9);
    var oz: f64 = amp * 0.1 * sin(pi * 1.3);
    var s: i64 = 0;
    while s < max_steps {
        let e: f64 = enstrophy3(ox, oy, oz);
        if e > 100.0 { return 1; }
        let n0: f64 = step6(u, v, w, ox, oy, oz, nu, sigma, lambda, lambda2, dt, 0);
        let n1: f64 = step6(u, v, w, ox, oy, oz, nu, sigma, lambda, lambda2, dt, 1);
        let n2: f64 = step6(u, v, w, ox, oy, oz, nu, sigma, lambda, lambda2, dt, 2);
        let n3: f64 = step6(u, v, w, ox, oy, oz, nu, sigma, lambda, lambda2, dt, 3);
        let n4: f64 = step6(u, v, w, ox, oy, oz, nu, sigma, lambda, lambda2, dt, 4);
        let n5: f64 = step6(u, v, w, ox, oy, oz, nu, sigma, lambda, lambda2, dt, 5);
        u = n0; v = n1; w = n2; ox = n3; oy = n4; oz = n5;
        s = s + 1;
    }
    0
}

// H' — self-adapting H with learnable weights
// Returns: 0 = safe, 1 = blow-up predicted
// Also prints weight evolution and H' trajectory
fn h_prime_run(amp: f64, nu: f64, sigma: f64, lambda: f64, lambda2: f64,
               dt: f64, max_steps: i64, verbose: i64) -> i64 {
    let pi: f64 = 3.14159265358979;
    var u: f64 = amp * sin(pi * 0.3);
    var v: f64 = amp * sin(pi * 0.7);
    var w_v: f64 = amp * sin(pi * 1.1);
    var ox: f64 = amp * 0.1 * sin(pi * 0.5);
    var oy: f64 = amp * 0.1 * sin(pi * 0.9);
    var oz: f64 = amp * 0.1 * sin(pi * 1.3);

    let e0: f64 = enstrophy3(ox, oy, oz);

    // 8 learnable weights (for 8 key levels)
    // w0: enstrophy normalised (L1)
    // w1: convergence S (L2)
    // w2: fragility proxy (L4)
    // w3: production ratio (C1/L11)
    // w4: doubling time trend (L15)
    // w5: fluctuation ratio (L16)
    // w6: relaxation deficit (L18)
    // w7: enstrophy acceleration (L11)
    var w0: f64 = 0.125;
    var w1: f64 = 0.125;
    var w2: f64 = 0.125;
    var w3: f64 = 0.125;
    var w4: f64 = 0.125;
    var w5: f64 = 0.125;
    var w6: f64 = 0.125;
    var w7: f64 = 0.125;

    let eta: f64 = 0.01;
    var s: i64 = 0;
    var prev_e: f64 = e0;
    var prev_e2: f64 = e0;
    var prev_de: f64 = 0.0;
    var ema_de: f64 = 0.0;
    var ema_d2e: f64 = 0.0;
    var mean_e: f64 = e0;
    var prev_h: f64 = 0.0;
    var prev_dh: f64 = 0.0;

    // Doubling time state
    var base_e: f64 = e0;
    var target_e: f64 = base_e * 2.0;
    var prev_dbl_time: f64 = 0.0;
    var dbl_start: i64 = 0;
    var dbl_shrinking: f64 = 0.0;

    // Prediction tracking for weight updates
    var last_predict: f64 = 0.0;
    var predict_correct_count: i64 = 0;
    var predict_total_count: i64 = 0;

    // H' tracking
    var h_prime_sum: f64 = 0.0;
    var h_prime_count: i64 = 0;

    var blow_detected: i64 = 0;

    while s < max_steps {
        let e: f64 = enstrophy3(ox, oy, oz);
        if e > 100.0 {
            blow_detected = 1;
            s = max_steps;
        } else {
            let k: f64 = kinetic3(u, v, w_v);
            let omega_sq: f64 = ox * ox + oy * oy + oz * oz;

            // Compute all level values
            let de: f64 = e - prev_e;
            let d2e: f64 = de - prev_de;
            ema_de = 0.0003 * de + 0.9997 * ema_de;
            ema_d2e = 0.0003 * d2e + 0.9997 * ema_d2e;
            mean_e = 0.0001 * e + 0.9999 * mean_e;

            // L1: normalised enstrophy
            var l_enst: f64 = 0.0;
            if e0 > 0.00001 { l_enst = e / e0; }

            // L2: convergence estimate
            let de_now: f64 = abs_f64(e - prev_e);
            let de_old: f64 = abs_f64(prev_e - prev_e2);
            var l_conv: f64 = 0.0;
            if de_old > 0.0000001 { l_conv = 1.0 - de_now / de_old; }
            else { if de_now < 0.0000001 { l_conv = 1.0; } else { l_conv = 0.0 - 1.0; } }

            // L4: fragility
            var l_frag: f64 = 1.0;
            if e > prev_e { l_frag = 1.0 + (e - prev_e) / (e + 0.001); }

            // L11/C1: production ratio
            let diff_rate: f64 = nu * 4.0 * omega_sq;
            let sox: f64 = lambda * (oy * w_v + oz * u) + lambda2 * omega_sq * ox;
            let soy: f64 = lambda * (oz * u + ox * w_v) + lambda2 * omega_sq * oy;
            let soz: f64 = lambda * (ox * v + oy * u) + lambda2 * omega_sq * oz;
            let stretch: f64 = ox * sox + oy * soy + oz * soz;
            var l_prod: f64 = 0.0;
            if diff_rate > 0.0000001 { l_prod = stretch / diff_rate; }

            // L15: doubling time trend
            if e >= target_e {
                let dtime: f64 = (s - dbl_start) as f64;
                if prev_dbl_time > 0.1 {
                    if dtime < prev_dbl_time * 0.9 { dbl_shrinking = dbl_shrinking + 1.0; }
                    else { dbl_shrinking = dbl_shrinking * 0.5; }
                }
                prev_dbl_time = dtime;
                base_e = e; target_e = base_e * 2.0; dbl_start = s;
            }
            if e < base_e * 0.5 {
                base_e = e; target_e = base_e * 2.0; dbl_start = s;
                prev_dbl_time = 0.0; dbl_shrinking = 0.0;
            }
            let l_dbl: f64 = dbl_shrinking;

            // L16: fluctuation ratio
            var l_fluct: f64 = 0.0;
            if mean_e > 0.0000001 { l_fluct = abs_f64(e - mean_e) / mean_e; }

            // L18: relaxation deficit
            var l_relax: f64 = 0.0;
            if diff_rate > 0.0000001 { l_relax = abs_f64(stretch) / diff_rate; }

            // L11: enstrophy acceleration
            var l_accel: f64 = 0.0;
            if ema_de > 0.0 {
                if ema_d2e > 0.0 { l_accel = ema_d2e / (ema_de + 0.0000001); }
            }

            // Compute H with current weights
            // Normalise dangerous signals to [0,1] range
            var s_enst: f64 = l_enst / (l_enst + 1.0);
            var s_conv: f64 = (0.0 - l_conv + 1.0) / 2.0;
            var s_frag: f64 = (l_frag - 1.0) * 10.0;
            if s_frag > 1.0 { s_frag = 1.0; }
            if s_frag < 0.0 { s_frag = 0.0; }
            var s_prod: f64 = 0.0;
            if l_prod > 1.0 { s_prod = (l_prod - 1.0) / l_prod; }
            var s_dbl: f64 = l_dbl / (l_dbl + 3.0);
            var s_fluct: f64 = l_fluct / (l_fluct + 1.0);
            var s_relax: f64 = 0.0;
            if l_relax > 5.0 { s_relax = (l_relax - 5.0) / l_relax; }
            var s_accel: f64 = l_accel / (l_accel + 1.0);

            let h: f64 = w0 * s_enst + w1 * s_conv + w2 * s_frag
                       + w3 * s_prod + w4 * s_dbl + w5 * s_fluct
                       + w6 * s_relax + w7 * s_accel;

            let dh: f64 = h - prev_h;

            // H' = rate of change of H's weight vector
            // Compute at checkpoints
            let check: i64 = s - (s / 2000) * 2000;
            if check == 0 {
                if s > 2000 {
                    // Prediction: is H increasing? (blow-up signal)
                    let predicting_blowup: f64 = if dh > 0.001 { 1.0 } else { 0.0 };

                    // Validate against short-term future (next 2000 steps)
                    // Use enstrophy growth as ground truth for this window
                    let future_growth: f64 = if ema_de > 0.0 { 1.0 } else { 0.0 };

                    // Each level's contribution to the prediction
                    let level_signals_0: f64 = s_enst;
                    let level_signals_1: f64 = s_conv;
                    let level_signals_2: f64 = s_frag;
                    let level_signals_3: f64 = s_prod;
                    let level_signals_4: f64 = s_dbl;
                    let level_signals_5: f64 = s_fluct;
                    let level_signals_6: f64 = s_relax;
                    let level_signals_7: f64 = s_accel;

                    // Update weights: increase if signal agrees with outcome
                    if predicting_blowup > 0.5 {
                        if future_growth > 0.5 {
                            // Correct blow-up prediction — reward contributing signals
                            w0 = w0 + eta * level_signals_0;
                            w1 = w1 + eta * level_signals_1;
                            w2 = w2 + eta * level_signals_2;
                            w3 = w3 + eta * level_signals_3;
                            w4 = w4 + eta * level_signals_4;
                            w5 = w5 + eta * level_signals_5;
                            w6 = w6 + eta * level_signals_6;
                            w7 = w7 + eta * level_signals_7;
                            predict_correct_count = predict_correct_count + 1;
                        } else {
                            // False positive — penalise contributing signals
                            w0 = w0 - eta * level_signals_0;
                            w1 = w1 - eta * level_signals_1;
                            w2 = w2 - eta * level_signals_2;
                            w3 = w3 - eta * level_signals_3;
                            w4 = w4 - eta * level_signals_4;
                            w5 = w5 - eta * level_signals_5;
                            w6 = w6 - eta * level_signals_6;
                            w7 = w7 - eta * level_signals_7;
                        }
                    } else {
                        if future_growth < 0.5 {
                            predict_correct_count = predict_correct_count + 1;
                        }
                    }
                    predict_total_count = predict_total_count + 1;

                    // Clamp weights to [0.01, 1.0]
                    if w0 < 0.01 { w0 = 0.01; } if w0 > 1.0 { w0 = 1.0; }
                    if w1 < 0.01 { w1 = 0.01; } if w1 > 1.0 { w1 = 1.0; }
                    if w2 < 0.01 { w2 = 0.01; } if w2 > 1.0 { w2 = 1.0; }
                    if w3 < 0.01 { w3 = 0.01; } if w3 > 1.0 { w3 = 1.0; }
                    if w4 < 0.01 { w4 = 0.01; } if w4 > 1.0 { w4 = 1.0; }
                    if w5 < 0.01 { w5 = 0.01; } if w5 > 1.0 { w5 = 1.0; }
                    if w6 < 0.01 { w6 = 0.01; } if w6 > 1.0 { w6 = 1.0; }
                    if w7 < 0.01 { w7 = 0.01; } if w7 > 1.0 { w7 = 1.0; }

                    // Normalise weights to sum to 1
                    let wsum: f64 = w0 + w1 + w2 + w3 + w4 + w5 + w6 + w7;
                    w0 = w0 / wsum; w1 = w1 / wsum; w2 = w2 / wsum;
                    w3 = w3 / wsum; w4 = w4 / wsum; w5 = w5 / wsum;
                    w6 = w6 / wsum; w7 = w7 / wsum;

                    // H' = magnitude of weight change
                    let h_prime: f64 = abs_f64(dh - prev_dh);
                    h_prime_sum = h_prime_sum + h_prime;
                    h_prime_count = h_prime_count + 1;

                    if verbose == 1 {
                        print("  "); print_i64(s);
                        print("  H="); print_f64(h);
                        print("  H'="); print_f64(h_prime);
                        print("  w=[");
                        print_f64(w0); print(",");
                        print_f64(w3); print(",");
                        print_f64(w4); print(",");
                        print_f64(w6);
                        print("]");
                        var acc: f64 = 0.0;
                        if predict_total_count > 0 {
                            acc = (predict_correct_count as f64) / (predict_total_count as f64);
                        }
                        print("  acc="); print_f64(acc);
                        println("");
                    }
                }
            }

            prev_dh = dh;
            prev_h = h;
            prev_de = de;
            prev_e2 = prev_e;
            prev_e = e;

            let n0: f64 = step6(u, v, w_v, ox, oy, oz, nu, sigma, lambda, lambda2, dt, 0);
            let n1: f64 = step6(u, v, w_v, ox, oy, oz, nu, sigma, lambda, lambda2, dt, 1);
            let n2: f64 = step6(u, v, w_v, ox, oy, oz, nu, sigma, lambda, lambda2, dt, 2);
            let n3: f64 = step6(u, v, w_v, ox, oy, oz, nu, sigma, lambda, lambda2, dt, 3);
            let n4: f64 = step6(u, v, w_v, ox, oy, oz, nu, sigma, lambda, lambda2, dt, 4);
            let n5: f64 = step6(u, v, w_v, ox, oy, oz, nu, sigma, lambda, lambda2, dt, 5);
            u = n0; v = n1; w_v = n2; ox = n3; oy = n4; oz = n5;
            s = s + 1;
        }
    }

    // Final decision: was dbl_shrinking high enough?
    if blow_detected == 1 { return 1; }
    if dbl_shrinking > 2.0 { return 1; }
    // Adaptive threshold based on learned weights
    if w4 > 0.3 {
        // H' learned that doubling time is dominant
        if dbl_shrinking > 1.0 { return 1; }
    }
    0
}

// ============================================================================
// Exp 1: H' Weight Evolution — Watch the Weights Learn
// ============================================================================

fn test_weight_evolution() -> i64 {
    println("=== Exp 1: H' Weight Evolution ===");
    println("  8 weights, initially equal (0.125 each)");
    println("  Watch which levels H' learns to trust");
    println("");

    let nu: f64 = 0.005;
    let sigma: f64 = 0.5;
    let lambda: f64 = 1.0;
    let lambda2: f64 = 5.0;
    let dt: f64 = 0.0001;
    let max_s: i64 = 40000;

    println("  --- A=1.2 (blow-up) ---");
    println("  Step  H       H'       w=[enst, prod, dbl, relax]  accuracy");
    let r1: i64 = h_prime_run(1.2, nu, sigma, lambda, lambda2, dt, max_s, 1);
    println("");

    println("  --- A=0.5 (safe) ---");
    println("  Step  H       H'       w=[enst, prod, dbl, relax]  accuracy");
    let r2: i64 = h_prime_run(0.5, nu, sigma, lambda, lambda2, dt, max_s, 1);
    println("");

    println("  --- A=1.0 (safe, grey zone) ---");
    println("  Step  H       H'       w=[enst, prod, dbl, relax]  accuracy");
    let r3: i64 = h_prime_run(1.0, nu, sigma, lambda, lambda2, dt, max_s, 1);
    println("");
    0
}

// ============================================================================
// Exp 2: Does H' Improve A*?
// ============================================================================

fn test_h_prime_threshold() -> i64 {
    println("=== Exp 2: A* with H' (self-adapting weights) ===");
    println("");

    let nu: f64 = 0.005;
    let sigma: f64 = 0.5;
    let lambda: f64 = 1.0;
    let lambda2: f64 = 5.0;
    let dt: f64 = 0.0001;
    let max_s: i64 = 50000;

    // Ground truth
    var lo: f64 = 0.5; var hi: f64 = 2.0; var iter: i64 = 0;
    while iter < 14 {
        let mid: f64 = (lo + hi) / 2.0;
        if actually_blows_up(mid, nu, sigma, lambda, lambda2, dt, max_s) == 1 { hi = mid; } else { lo = mid; }
        iter = iter + 1;
    }
    let at: f64 = (lo + hi) / 2.0;

    // H' A*
    lo = 0.5; hi = 2.0; iter = 0;
    while iter < 14 {
        let mid: f64 = (lo + hi) / 2.0;
        if h_prime_run(mid, nu, sigma, lambda, lambda2, dt, max_s, 0) == 1 { hi = mid; } else { lo = mid; }
        iter = iter + 1;
    }
    let ah: f64 = (lo + hi) / 2.0;

    let gap: f64 = at - 0.298;

    println("  Ground truth A*: ");
    print("    "); print_f64(at); println("");
    println("  Previous best P: ");
    print("    1.020  (86.1%)"); println("");
    println("  H' (self-adapting): ");
    print("    "); print_f64(ah);
    print("  ("); print_f64((ah - 0.298) / gap * 100.0); println("%)");
    println("");
    0
}

// ============================================================================
// Exp 3: Convergence Speed — How Fast Does H' Resolve?
//
// Run H' at the same amplitude with 3, 5, 8 levels.
// Measure how many steps until the prediction stabilises.
// More levels → faster stabilisation → quicker resolution.
// ============================================================================

fn h_prime_convergence(amp: f64, nu: f64, sigma: f64, lambda: f64, lambda2: f64,
                       dt: f64, max_steps: i64, n_levels: i64) -> i64 {
    // Simplified: run with n_levels active (others zeroed)
    // Count steps until accuracy reaches 80%
    let pi: f64 = 3.14159265358979;
    var u: f64 = amp * sin(pi * 0.3);
    var v: f64 = amp * sin(pi * 0.7);
    var w_v: f64 = amp * sin(pi * 1.1);
    var ox: f64 = amp * 0.1 * sin(pi * 0.5);
    var oy: f64 = amp * 0.1 * sin(pi * 0.9);
    var oz: f64 = amp * 0.1 * sin(pi * 1.3);
    let e0: f64 = enstrophy3(ox, oy, oz);

    var s: i64 = 0;
    var prev_e: f64 = e0;
    var prev_e2: f64 = e0;
    var prev_de: f64 = 0.0;
    var ema_de: f64 = 0.0;
    var correct: i64 = 0;
    var total: i64 = 0;
    var converged_step: i64 = max_steps;

    while s < max_steps {
        let e: f64 = enstrophy3(ox, oy, oz);
        if e > 100.0 { s = max_steps; }
        else {
            let de: f64 = e - prev_e;
            ema_de = 0.0003 * de + 0.9997 * ema_de;

            let check: i64 = s - (s / 2000) * 2000;
            if check == 0 {
                if s > 2000 {
                    // Simple prediction using available levels
                    var predict_blow: i64 = 0;
                    // Level 1: enstrophy growing
                    if n_levels >= 1 { if ema_de > 0.0 { predict_blow = predict_blow + 1; } }
                    // Level 2: convergence failing
                    if n_levels >= 2 {
                        let dn: f64 = abs_f64(e - prev_e);
                        let do2: f64 = abs_f64(prev_e - prev_e2);
                        if do2 > 0.0000001 { if dn > do2 { predict_blow = predict_blow + 1; } }
                    }
                    // Level 3: production > 1
                    if n_levels >= 3 {
                        let omega_sq: f64 = ox * ox + oy * oy + oz * oz;
                        let dr: f64 = nu * 4.0 * omega_sq;
                        let sx: f64 = lambda * (oy * w_v + oz * u) + lambda2 * omega_sq * ox;
                        let sy: f64 = lambda * (oz * u + ox * w_v) + lambda2 * omega_sq * oy;
                        let sz: f64 = lambda * (ox * v + oy * u) + lambda2 * omega_sq * oz;
                        let sr: f64 = ox * sx + oy * sy + oz * sz;
                        if dr > 0.0000001 { if sr / dr > 1.0 { predict_blow = predict_blow + 1; } }
                    }
                    // Levels 4-8: additional signals (simplified)
                    if n_levels >= 5 {
                        let d2e: f64 = de - prev_de;
                        if d2e > 0.0 { if ema_de > 0.0 { predict_blow = predict_blow + 1; } }
                    }
                    if n_levels >= 8 {
                        var flu: f64 = 0.0;
                        if e0 > 0.00001 { flu = abs_f64(e - e0 * 0.5) / e0; }
                        if flu > 0.3 { predict_blow = predict_blow + 1; }
                    }

                    // Threshold: majority vote
                    let threshold: i64 = n_levels / 2;
                    let predicted: i64 = if predict_blow > threshold { 1 } else { 0 };

                    // Ground truth for this window
                    let actual: i64 = if ema_de > 0.0 { 1 } else { 0 };
                    if predicted == actual { correct = correct + 1; }
                    total = total + 1;

                    // Check convergence: 80% accuracy over last 5 predictions
                    if total >= 5 {
                        let recent_acc: f64 = (correct as f64) / (total as f64);
                        if recent_acc >= 0.8 {
                            if converged_step == max_steps { converged_step = s; }
                        }
                    }
                }
            }

            prev_de = de; prev_e2 = prev_e; prev_e = e;
            let n0: f64 = step6(u, v, w_v, ox, oy, oz, nu, sigma, lambda, lambda2, dt, 0);
            let n1: f64 = step6(u, v, w_v, ox, oy, oz, nu, sigma, lambda, lambda2, dt, 1);
            let n2: f64 = step6(u, v, w_v, ox, oy, oz, nu, sigma, lambda, lambda2, dt, 2);
            let n3: f64 = step6(u, v, w_v, ox, oy, oz, nu, sigma, lambda, lambda2, dt, 3);
            let n4: f64 = step6(u, v, w_v, ox, oy, oz, nu, sigma, lambda, lambda2, dt, 4);
            let n5: f64 = step6(u, v, w_v, ox, oy, oz, nu, sigma, lambda, lambda2, dt, 5);
            u = n0; v = n1; w_v = n2; ox = n3; oy = n4; oz = n5;
            s = s + 1;
        }
    }
    converged_step
}

fn test_convergence_speed() -> i64 {
    println("=== Exp 3: Convergence Speed vs Number of Levels ===");
    println("  More levels → faster resolution of blow-up/safe question");
    println("");

    let nu: f64 = 0.005;
    let sigma: f64 = 0.5;
    let lambda: f64 = 1.0;
    let lambda2: f64 = 5.0;
    let dt: f64 = 0.0001;
    let max_s: i64 = 40000;

    println("  Amplitude  Levels  Converged at   Steps saved");

    var ai: i64 = 0;
    while ai < 3 {
        var amp: f64 = 1.2;
        if ai == 1 { amp = 0.8; }
        if ai == 2 { amp = 1.0; }

        var li: i64 = 0;
        var prev_conv: i64 = max_s;
        while li < 4 {
            var n_levels: i64 = 1;
            if li == 1 { n_levels = 3; }
            if li == 2 { n_levels = 5; }
            if li == 3 { n_levels = 8; }

            let conv: i64 = h_prime_convergence(amp, nu, sigma, lambda, lambda2, dt, max_s, n_levels);

            print("  ");
            print_f64(amp);
            print("     ");
            print_i64(n_levels);
            print("      ");
            if conv < max_s {
                print_i64(conv);
                print("        ");
                if prev_conv < max_s {
                    let saved: i64 = prev_conv - conv;
                    if saved > 0 { print("+"); print_i64(saved); }
                    else { print("0"); }
                } else { print("(baseline)"); }
            } else {
                print("NEVER         ");
                print("---");
            }
            println("");

            prev_conv = conv;
            li = li + 1;
        }
        println("");
        ai = ai + 1;
    }

    println("  If convergence step DECREASES with more levels →");
    println("  each new level helps H' resolve faster.");
    println("  This is the fundamental theorem of H':");
    println("  MORE SENSORS = FASTER TRIANGULATION.");
    println("");
    0
}

