    println("#  = quicker resolution of blow-up vs safe.               #");
    println("#                                                          #");
    println("#  Each level helps H' triangulate. Even weak levels      #");
    println("#  constrain the solution space.                          #");
    println("############################################################");
    println("");

    test_weight_evolution();
    test_h_prime_threshold();
    test_convergence_speed();

    println("############################################################");
    println("#  H' — WHAT WE LEARNED:                                  #");
    println("#                                                          #");
    println("#  1. H' learns which levels to trust (weight evolution)   #");
    println("#  2. The learned weights are trajectory-dependent         #");
    println("#  3. More levels → faster convergence → quicker answer   #");
    println("#  4. H' is the self-learning annealing principle applied #");
    println("#     to the diagnostic itself                            #");
    println("#                                                          #");
    println("#  The scaffold doesn't just monitor the system.           #");
    println("#  It monitors itself monitoring the system.               #");
    println("#  And it LEARNS to do it better.                         #");
    println("############################################################");

    0
}
