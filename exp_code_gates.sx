// Main
// ============================================================================

fn main() -> i64 {
    println("################################################################");
    println("#  Geometric Contraction Framework: Code Optimisation Gates    #");
    println("################################################################");
    println("");

    var r1: i64 = run_exp1();
    var r2: i64 = run_exp2();
    var r3: i64 = run_exp3();

    println("================================================================");
    println("  ALL EXPERIMENTS COMPLETE");
    println("================================================================");

    0
}
