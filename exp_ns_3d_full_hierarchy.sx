    println("#  - Spectrum mapping with stretching                      #");
    println("#  - Resonance detection and shift                        #");
    println("#  - Hysteresis with vortex stretching                    #");
    println("#  - Level 10 trajectory meta-gradient in 3D              #");
    println("#  - Full 10-level profile on blow-up trajectory          #");
    println("############################################################");
    println("");

    test_3d_spectrum();
    test_3d_resonance();
    test_3d_hysteresis();
    test_3d_trajectory();
    test_resonance_shift();
    test_3d_full_profile();

    println("############################################################");
    println("#  3D NS FULL HIERARCHY — SUMMARY:                        #");
    println("#                                                          #");
    println("#  1. Does stretching shift the viscosity spectrum?        #");
    println("#  2. Does stretching shift the resonance frequency?      #");
    println("#  3. Does stretching amplify hysteresis?                  #");
    println("#  4. Does Level 10 meta-gradient change with stretching? #");
    println("#  5. Where does the resonance move in 3D?                #");
    println("#  6. Full 10-level blow-up trajectory in 3D              #");
    println("#                                                          #");
    println("#  These answers characterise HOW vortex stretching       #");
    println("#  interacts with the viscosity spectrum —                 #");
    println("#  the coupling between Levels 9 and 10.                  #");
    println("############################################################");

    0
}
